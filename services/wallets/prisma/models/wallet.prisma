model Wallet {
  id        String   @id @default(uuid())
  balance   BigInt   @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  playerId String  @unique @map("player_id")
  player   Player?

  transactions Transaction[]

  @@map("wallets")
}

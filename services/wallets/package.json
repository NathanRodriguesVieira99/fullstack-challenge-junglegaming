{
  "name": "@crash/wallets",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/main.ts",
    "start": "bun run src/main.ts",
    "test:unit": "vitest run --bail 1",
    "test:watch:unit": " vitest watch --bail 1",
    "test:cov:unit": " vitest run --coverage",
    "pretest:e2e": "NODE_ENV=test DATABASE_URL=\"postgresql://admin:admin@localhost:5432/wallets_test\" prisma migrate deploy",
    "test:e2e": "NODE_ENV=test DATABASE_URL=\"postgresql://admin:admin@localhost:5432/wallets_test\" vitest run --config ./tests/e2e/vitest.config.e2e.ts",
    "test:cov:e2e": "NODE_ENV=test DATABASE_URL=\"postgresql://admin:admin@localhost:5432/wallets_test\" vitest run --config ./tests/e2e/vitest.config.e2e.ts --coverage",
    "db:migrate": " NODE_ENV=development DATABASE_URL=\"postgresql://admin:admin@localhost:5432/wallets\" prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:generate": " NODE_ENV=development DATABASE_URL=\"postgresql://admin:admin@localhost:5432/wallets\" prisma generate",
    "db:studio": "NODE_ENV=development DATABASE_URL=\"postgresql://admin:admin@localhost:5432/wallets\" prisma studio",
    "db:seed": " NODE_ENV=development DATABASE_URL=\"postgresql://admin:admin@localhost:5432/wallets\" prisma db seed"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.17",
    "@nestjs/core": "^11.1.17",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.1.17",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/testing": "^11.1.17",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@vitest/coverage-v8": "^4.1.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.3.1",
    "jwks-rsa": "^4.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "vitest": "^4.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@nestjs/swagger": "^11.2.6",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "bun-types": "latest",
    "kafkajs": "^2.2.4",
    "prisma": "^7.5.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}

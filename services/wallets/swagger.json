{
  "openapi": "3.0.0",
  "paths": {
    "/health": {
      "get": {
        "operationId": "healthCheck",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthCheckResponseDto"
                }
              }
            }
          }
        },
        "summary": "Check service health",
        "tags": [
          "Health"
        ]
      }
    },
    "/wallets/me": {
      "get": {
        "description": "Retrieves the wallet associated with the authenticated player. Returns wallet details including current balance, creation date, and last update timestamp.",
        "operationId": "getPlayerWallet",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Wallet successfully retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateWalletResponseDto"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing JWT token"
          },
          "404": {
            "description": "Wallet not found for the authenticated player"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Get authenticated player's wallet",
        "tags": [
          "Wallets"
        ]
      }
    },
    "/wallets": {
      "post": {
        "description": "Creates a new wallet for the authenticated player with an initial balance of 1000.00. Each player can only have one wallet.",
        "operationId": "createWallet",
        "parameters": [],
        "responses": {
          "201": {
            "description": "Wallet successfully created with initial balance",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateWalletResponseDto"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing JWT token"
          },
          "409": {
            "description": "Conflict - Player already has an existing wallet"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Create a new wallet for the player",
        "tags": [
          "Wallets"
        ]
      }
    },
    "/wallets/credit": {
      "post": {
        "operationId": "CreditController_credit",
        "parameters": [],
        "responses": {
          "201": {
            "description": ""
          }
        },
        "tags": [
          "Wallets - Credit"
        ]
      }
    }
  },
  "info": {
    "title": "Service de Wallets",
    "description": "Documentação referente ao serviço de Wallet",
    "version": "0.0.1",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "schemas": {
      "HealthCheckResponseDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Current health status of the service",
            "example": "ok"
          },
          "service": {
            "type": "string",
            "description": "Name of the service reporting health status",
            "example": "wallets"
          }
        },
        "required": [
          "status",
          "service"
        ]
      },
      "CreateWalletResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier of the wallet",
            "example": "123e4567-e89b-12d3-a456-426614174001",
            "format": "uuid"
          },
          "playerId": {
            "type": "string",
            "description": "Unique identifier of the player who owns the wallet",
            "example": "123e4567-e89b-12d3-a456-426614174000",
            "format": "uuid"
          },
          "balance": {
            "type": "string",
            "description": "Current wallet balance in decimal format",
            "example": "1000.00"
          },
          "createdAt": {
            "type": "string",
            "description": "Timestamp when the wallet was created",
            "example": "2024-01-15T10:30:00.000Z"
          }
        },
        "required": [
          "id",
          "playerId",
          "balance",
          "createdAt"
        ]
      }
    }
  }
}
{
  "openapi": "3.0.0",
  "paths": {
    "/health": {
      "get": {
        "operationId": "healthCheck",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthCheckResponseDto"
                }
              }
            }
          }
        },
        "summary": "Check service health",
        "tags": [
          "Health"
        ]
      }
    },
    "/wallets/me": {
      "get": {
        "description": "Retorna os dados da carteira do jogador autenticado",
        "operationId": "GetWallet",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Carteira retornada com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/createWalletDto"
                }
              }
            }
          },
          "401": {
            "description": "Usuário não autorizado (Token JWT inválido ou ausente)"
          },
          "404": {
            "description": "Carteira não encontrada"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Obter carteira do jogador",
        "tags": [
          "Wallets"
        ]
      }
    },
    "/wallets": {
      "post": {
        "description": "Cria uma carteira para o jogador",
        "operationId": "CreateWallet",
        "parameters": [],
        "responses": {
          "201": {
            "description": "Carteira criada com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/createWalletDto"
                }
              }
            }
          },
          "401": {
            "description": "Usuário não autorizado (Token JWT inválido ou ausente)"
          },
          "409": {
            "description": "Usuário já possui uma carteira"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Cria uma carteira para usuário autenticado com 1000 de saldo inicial",
        "tags": [
          "Wallets"
        ]
      }
    }
  },
  "info": {
    "title": "Service de Wallets",
    "description": "Documentação referente ao serviço de Wallet",
    "version": "0.0.1",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "schemas": {
      "HealthCheckResponseDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": 200
          },
          "service": {
            "type": "string",
            "example": "ok"
          }
        },
        "required": [
          "status",
          "service"
        ]
      },
      "createWalletDto": {
        "type": "object",
        "properties": {
          "playerId": {
            "type": "string",
            "example": "sdjkwejjhsdkmskdhjuedfsndjm...",
            "format": "uuid"
          },
          "balance": {
            "format": "int64",
            "type": "integer",
            "example": "1000",
            "description": "é BigInt porém vira string após ser sanitizado"
          }
        },
        "required": [
          "playerId",
          "balance"
        ]
      }
    }
  }
}
{
  "openapi": "3.0.0",
  "paths": {
    "/health": {
      "get": {
        "operationId": "healthCheck",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthCheckResponseDto"
                }
              }
            }
          }
        },
        "summary": "Verifica a saúde do serviço",
        "tags": [
          "Health"
        ]
      }
    },
    "/wallets/me": {
      "get": {
        "description": "Retorna os detalhes da carteira associada ao jogador autenticado, incluindo saldo atual, data de criação e última atualização.",
        "operationId": "getPlayerWallet",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Carteira retornada com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateWalletResponseDto"
                }
              }
            }
          },
          "401": {
            "description": "Não autorizado - Token JWT inválido ou ausente"
          },
          "404": {
            "description": "Carteira não encontrada para o jogador autenticado"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Retorna a carteira do jogador autenticado",
        "tags": [
          "Wallets"
        ]
      }
    },
    "/wallets": {
      "post": {
        "description": "Cria uma nova carteira para o jogador autenticado com saldo inicial de 1000.00. Cada jogador pode ter apenas uma carteira.",
        "operationId": "createWallet",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateWalletRequestDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Carteira criada com sucesso com saldo inicial",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateWalletResponseDto"
                }
              }
            }
          },
          "401": {
            "description": "Não autorizado - Token JWT inválido ou ausente"
          },
          "409": {
            "description": "Conflito - Jogador já possui uma carteira"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Cria uma nova carteira para o jogador",
        "tags": [
          "Wallets"
        ]
      }
    },
    "/credit": {
      "post": {
        "operationId": "CreditController_credit",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreditRequestDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": ""
          }
        },
        "tags": [
          "credit"
        ]
      }
    },
    "/debit": {
      "post": {
        "operationId": "DebitController_debit",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DebitRequestDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": ""
          }
        },
        "tags": [
          "debit"
        ]
      }
    }
  },
  "info": {
    "title": "Service de Wallets",
    "description": "Documentação referente ao serviço de Wallet",
    "version": "0.0.1",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "schemas": {
      "HealthCheckResponseDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Status atual de saúde do serviço",
            "example": "ok"
          },
          "service": {
            "type": "string",
            "description": "Nome do serviço que está reportando",
            "example": "wallets"
          }
        },
        "required": [
          "status",
          "service"
        ]
      },
      "CreateWalletResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "ID único da carteira",
            "example": "123e4567-e89b-12d3-a456-426614174001",
            "format": "uuid"
          },
          "playerId": {
            "type": "string",
            "description": "ID do jogador que possui a carteira",
            "example": "123e4567-e89b-12d3-a456-426614174000",
            "format": "uuid"
          },
          "balance": {
            "type": "string",
            "description": "Saldo atual da carteira",
            "example": "1000.00"
          },
          "createdAt": {
            "type": "string",
            "description": "Data e hora de criação da carteira",
            "example": "2024-01-15T10:30:00.000Z"
          }
        },
        "required": [
          "id",
          "playerId",
          "balance",
          "createdAt"
        ]
      },
      "CreateWalletRequestDto": {
        "type": "object",
        "properties": {
          "playerId": {
            "type": "string",
            "description": "ID único do jogador que possui a carteira",
            "example": "123e4567-e89b-12d3-a456-426614174000",
            "format": "uuid"
          },
          "balance": {
            "type": "string",
            "description": "Saldo inicial da carteira em formato decimal",
            "example": "1000.00"
          }
        },
        "required": [
          "playerId",
          "balance"
        ]
      },
      "CreditRequestDto": {
        "type": "object",
        "properties": {
          "playerId": {
            "type": "string",
            "description": "ID único do jogador",
            "example": "123e4567-e89b-12d3-a456-426614174000",
            "format": "uuid"
          },
          "transactionId": {
            "type": "string",
            "description": "ID único da transação (chave de idempotência)",
            "example": "txn-123e4567-e89b-12d3-a456-426614174002"
          },
          "walletId": {
            "type": "string",
            "description": "ID da carteira do jogador",
            "example": "123e4567-e89b-12d3-a456-426614174001",
            "format": "uuid"
          },
          "transactionValue": {
            "type": "string",
            "description": "Valor do crédito",
            "example": "50.00"
          }
        },
        "required": [
          "playerId",
          "transactionId",
          "walletId",
          "transactionValue"
        ]
      },
      "DebitRequestDto": {
        "type": "object",
        "properties": {
          "playerId": {
            "type": "string",
            "description": "ID único do jogador",
            "example": "123e4567-e89b-12d3-a456-426614174000",
            "format": "uuid"
          },
          "transactionId": {
            "type": "string",
            "description": "ID único da transação (chave de idempotência)",
            "example": "txn-123e4567-e89b-12d3-a456-426614174002"
          },
          "walletId": {
            "type": "string",
            "description": "ID da carteira do jogador",
            "example": "123e4567-e89b-12d3-a456-426614174001",
            "format": "uuid"
          },
          "transactionValue": {
            "type": "string",
            "description": "Valor do débito (aposta)",
            "example": "50.00"
          }
        },
        "required": [
          "playerId",
          "transactionId",
          "walletId",
          "transactionValue"
        ]
      }
    }
  }
}
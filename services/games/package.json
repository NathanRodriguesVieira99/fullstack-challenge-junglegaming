{
  "name": "@crash/games",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/main.ts",
    "start": "bun run src/main.ts",
    "test:unit": "vitest run --bail 1",
    "test:watch:unit": " vitest watch --bail 1",
    "test:cov:unit": " vitest run --coverage",
    "pretest:e2e": "prisma migrate deploy",
    "test:e2e": " vitest run --config ./tests/e2e/vitest.config.e2e.ts",
    "test:cov:e2e": " vitest run --config ./tests/e2e/vitest.config.e2e.ts --coverage",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "pnpm prisma db seed"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/microservices": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/platform-socket.io": "^11.1.17",
    "@nestjs/testing": "^11.1.17",
    "@nestjs/websockets": "^11.1.17",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@vitest/coverage-v8": "^4.1.1",
    "dotenv": "^17.3.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "vitest": "^4.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/swagger": "^11.2.6",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "bun-types": "latest",
    "kafkajs": "^2.2.4",
    "prisma": "^7.5.0",
    "supertest": "^7.2.2",
    "typescript": "^5.8.3"
  }
}

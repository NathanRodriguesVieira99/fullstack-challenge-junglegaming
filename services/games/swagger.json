{
  "openapi": "3.0.0",
  "paths": {
    "/health": {
      "get": {
        "operationId": "healthCheck",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthCheckResponseDto"
                }
              }
            }
          }
        },
        "summary": "Verifica a saúde do serviço",
        "tags": [
          "Health"
        ]
      }
    },
    "/games/bet": {
      "post": {
        "operationId": "CreateBetController_bet",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateBetRequestDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": ""
          }
        },
        "tags": [
          "Bet"
        ]
      }
    },
    "/games/bet/cashout": {
      "post": {
        "operationId": "CreateBetController_cashout",
        "parameters": [],
        "responses": {
          "201": {
            "description": ""
          }
        },
        "tags": [
          "Bet"
        ]
      }
    },
    "/games/bets/me": {
      "get": {
        "operationId": "betsHistory",
        "parameters": [
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "description": "Limite de dados por página",
            "schema": {
              "example": 10,
              "type": "number"
            }
          },
          {
            "name": "page",
            "required": false,
            "in": "query",
            "description": "Página atual",
            "schema": {
              "example": 1,
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Dados paginados das apostas do jogador",
            "content": {
              "application/json": {
                "schema": {
                  "example": {
                    "meta": {
                      "page": 1,
                      "limit": 10,
                      "total_items": 100,
                      "total_pages": 10
                    },
                    "data": [
                      {
                        "id": "bet-id",
                        "betStatus": "WIN",
                        "amount": "100.00",
                        "cashedOutAt": "2024-01-01T00:00:00.000Z",
                        "createdAt": "2024-01-01T00:00:00.000Z"
                      }
                    ]
                  }
                }
              }
            }
          }
        },
        "summary": "Busca o histórico das apostas pertencentes ao jogador",
        "tags": [
          "Bets"
        ]
      }
    },
    "/games/rounds/current": {
      "get": {
        "operationId": "RoundsController_currentRound",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "tags": [
          "Rounds"
        ]
      }
    },
    "/games/rounds/history": {
      "get": {
        "operationId": "RoundsController_roundHistory",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "tags": [
          "Rounds"
        ]
      }
    },
    "/games/rounds/{roundId}/verify": {
      "get": {
        "operationId": "RoundsController_verify",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "tags": [
          "Rounds"
        ]
      }
    }
  },
  "info": {
    "title": "Service de Games",
    "description": "Documentação referente ao serviço de Games",
    "version": "0.0.1",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "schemas": {
      "HealthCheckResponseDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Status atual de saúde do serviço",
            "example": "ok"
          },
          "service": {
            "type": "string",
            "description": "Nome do serviço que está reportando",
            "example": "games"
          }
        },
        "required": [
          "status",
          "service"
        ]
      },
      "Decimal2": {
        "type": "object",
        "properties": {}
      },
      "CreateBetRequestDto": {
        "type": "object",
        "properties": {
          "betId": {
            "type": "string",
            "description": "ID único da aposta"
          },
          "playerId": {
            "type": "string",
            "description": "ID único do jogador",
            "format": "uuid"
          },
          "amount": {
            "description": "Valor da aposta",
            "allOf": [
              {
                "$ref": "#/components/schemas/Decimal2"
              }
            ]
          },
          "betStatus": {
            "type": "string",
            "enum": [
              "PENDING",
              "WON",
              "LOST",
              "CASHED_OUT"
            ],
            "description": "Status da aposta"
          },
          "roundStatus": {
            "type": "string",
            "enum": [
              "WAITING",
              "RUNNING",
              "CRASHED",
              "FINALIZED"
            ],
            "description": "Status da rodada"
          },
          "roundId": {
            "type": "string",
            "description": "ID da rodada",
            "format": "uuid"
          }
        },
        "required": [
          "betId",
          "playerId",
          "amount",
          "betStatus",
          "roundStatus",
          "roundId"
        ]
      }
    }
  }
}
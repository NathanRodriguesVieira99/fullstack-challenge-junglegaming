{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@/*": ["./src/*"],
      "@tests/*": ["./tests/*"],
      "@controllers/*": ["./src/presentation/controllers/*"],
      "@services/*": ["./src/application/services/*"],
      "@dtos/*": ["./src/presentation/dtos/*"],
      "@db/*": ["./src/infrastructure/database/*"],
      "@gateways/*": ["./src/presentation/gateways/*"],
      "@models/*": ["./src/domain/entities/*"],
      "repos/*": ["./src/domain/repositories/*"]
    },
    "types": ["vitest/globals"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "tests"]
}
